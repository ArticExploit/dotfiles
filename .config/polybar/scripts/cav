#! /bin/bash

bar="‚ĖĀ‚Ėā‚ĖÉ‚ĖĄ‚ĖÖ‚ĖÜ‚Ėá‚Ėą"
dict="s/;//g;"

# creating "dictionary" to replace char with bar
i=0
while [ $i -lt ${#bar} ]
do
    dict="${dict}s/$i/${bar:$i:1}/g;"
    i=$((i=i+1))
done

#e = 7
" > $config_file

# run cava in the background
cava -p $config_file &

# reading data from fifo
while read -r cmd; do
    echo $cmd | sed $dict
done < $pipe
